; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Guidance"
config/description="A small puzzle game about using light to guide little characters to safety.
Currently planning to submit to the Portfolio Builders Week #24 game jam."
config/version="0.0.2"
config/tags=PackedStringArray("game_jam", "mini_gim_#3", "portfolio_builders_jam_week_#24")
run/main_scene="uid://77g3x2qihytk"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

ChainPlacement="*res://scripts/chains/chain-placement.gd"
LevelProcessor="*res://scripts/level-processor.gd"

[debug]

gdscript/warnings/untyped_declaration=2
gdscript/warnings/inferred_declaration=2
gdscript/warnings/unsafe_property_access=2
gdscript/warnings/unsafe_method_access=2
gdscript/warnings/unsafe_cast=2
gdscript/warnings/unsafe_call_argument=2

[display]

window/handheld/orientation=6

[editor]

naming/scene_name_casing=3
naming/script_name_casing=3

[editor_plugins]

enabled=PackedStringArray("res://addons/kanban_tasks/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "blue",
"res://models/": "green",
"res://resources/": "gray",
"res://scenes/": "pink",
"res://scripts/": "yellow"
}

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"detect_3d/compress_to": 1,
"editor/convert_colors_with_editor_theme": false,
"editor/scale_with_editor_scale": false,
"mipmaps/generate": false,
"mipmaps/limit": -1,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 0,
"roughness/src_normal": "",
"svg/scale": 1.0
}

